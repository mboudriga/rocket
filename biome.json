{
  "$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true,
    "defaultBranch": "main"
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "**/*.js",
      "**/*.jsx",
      "**/*.ts",
      "**/*.tsx",
      "**/*.json",
      "**/*.jsonc",
      "!**/node_modules",
      "!**/dist",
      "!**/build",
      "!**/.turbo",
      "!**/coverage",
      "!**/*.gen.ts",
      "!**/storybook-static",
      "!.claude/skills",
      "!**/coverage-results.json",
      "!**/.wxt"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100,
    "lineEnding": "lf"
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "jsxQuoteStyle": "double",
      "trailingCommas": "es5",
      "semicolons": "always",
      "arrowParentheses": "always"
    },
    "globals": [
      "vi",
      "describe",
      "it",
      "expect",
      "beforeEach",
      "afterEach",
      "beforeAll",
      "afterAll",
      "test"
    ]
  },
  "json": {
    "formatter": {
      "trailingCommas": "none"
    }
  },
  "linter": {
    "enabled": true,
    "domains": {
      "react": "recommended"
    },
    "rules": {
      "recommended": true,
      "complexity": {
        "noExcessiveCognitiveComplexity": {
          "level": "warn",
          "options": { "maxAllowedComplexity": 15 }
        },
        "noVoid": "off",
        "useLiteralKeys": "off"
      },
      "correctness": {
        "noUnusedImports": "error",
        "noUnusedVariables": "error",
        "noUnusedPrivateClassMembers": "error",
        "useExhaustiveDependencies": "warn",
        "useHookAtTopLevel": "error",
        "noUndeclaredVariables": "error"
      },
      "style": {
        "noNonNullAssertion": "warn",
        "useConst": "error",
        "useImportType": "error",
        "useExportType": "error",
        "useBlockStatements": "error",
        "useCollapsedElseIf": "error",
        "useConsistentArrayType": {
          "level": "error",
          "options": { "syntax": "generic" }
        },
        "useEnumInitializers": "off",
        "useNamingConvention": "off"
      },
      "suspicious": {
        "noExplicitAny": "warn",
        "noArrayIndexKey": "off",
        "noConsole": {
          "level": "warn",
          "options": { "allow": ["error", "warn", "info", "debug"] }
        },
        "noEmptyBlockStatements": "warn",
        "noDoubleEquals": "error",
        "noImportCycles": {
          "level": "error",
          "options": { "ignoreTypes": true }
        }
      },
      "nursery": {
        "noFloatingPromises": "error"
      },
      "a11y": {
        "useKeyWithClickEvents": "warn",
        "useValidAnchor": "error"
      },
      "security": {
        "noDangerouslySetInnerHtml": "warn"
      }
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": {
          "level": "on"
        }
      }
    }
  },
  "overrides": [
    {
      "includes": ["**/*.test.ts", "**/*.test.tsx", "**/*.spec.ts"],
      "linter": {
        "rules": {
          "suspicious": { "noExplicitAny": "off", "noEmptyBlockStatements": "off" },
          "style": { "noNonNullAssertion": "off" }
        }
      }
    },
    {
      "includes": [
        "**/*.story.tsx",
        "**/*.stories.tsx",
        "**/vite.config.ts",
        "**/vitest.config.ts"
      ],
      "linter": {
        "rules": {
          "style": { "noDefaultExport": "off" }
        }
      }
    },
    {
      "includes": ["**/.storybook/**"],
      "linter": {
        "rules": {
          "style": { "noDefaultExport": "off" },
          "suspicious": { "noExplicitAny": "off" },
          "complexity": { "noBannedTypes": "off" },
          "correctness": { "noUnsafeOptionalChaining": "off" }
        }
      }
    },
    {
      "includes": ["engine/rocket-ui/**"],
      "linter": {
        "rules": {
          "a11y": {
            "useAltText": "error",
            "useButtonType": "error",
            "useKeyWithClickEvents": "error"
          }
        }
      }
    },
    {
      "includes": ["apps/wxt-extension-starter/**"],
      "linter": {
        "rules": {
          "correctness": { "noUndeclaredVariables": "off" },
          "style": { "noDefaultExport": "off" }
        }
      }
    },
    {
      "includes": ["apps/test-app/**"],
      "linter": {
        "rules": {
          "style": { "noNonNullAssertion": "off" },
          "complexity": { "noExcessiveCognitiveComplexity": "off" },
          "performance": { "noDynamicNamespaceImportAccess": "off" }
        }
      }
    }
  ]
}
