{
  "productName": "Tauri Starter",
  "version": "0.0.1",
  "identifier": "com.rocket.tauristarter",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3006",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Tauri Starter",
        "width": 1200,
        "height": 800,
        "decorations": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
