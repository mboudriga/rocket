{
  "name": "@app/wxt-extension-starter",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "test": "vitest run",
    "clean": "rm -rf .output .wxt",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "@chakra-ui/react": "catalog:",
    "@rocket/ui": "workspace:*",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-icons": "catalog:"
  },
  "devDependencies": {
    "@engine/typescript-config": "workspace:*",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@wxt-dev/module-react": "catalog:",
    "typescript": "catalog:",
    "wxt": "catalog:"
  }
}
