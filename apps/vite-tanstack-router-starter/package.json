{
  "name": "@app/vite-tanstack-router-starter",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "start": "node dist/server/server.js",
    "typecheck": "tsc --noEmit",
    "typegen": "echo 'routeTree.gen.ts is auto-generated by tanstackStart() vite plugin'",
    "test:e2e": "playwright test",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:debug": "playwright test --debug",
    "e2e:headed": "playwright test --headed",
    "e2e:codegen": "playwright codegen http://localhost:3000",
    "clean": "rm -rf dist .tanstack node_modules/.vite"
  },
  "dependencies": {
    "@chakra-ui/react": "catalog:",
    "@emotion/react": "catalog:",
    "@rocket/ui": "workspace:*",
    "@tanstack/react-query": "catalog:",
    "@tanstack/react-query-devtools": "catalog:",
    "@tanstack/react-router": "catalog:",
    "@tanstack/react-router-devtools": "catalog:",
    "@tanstack/react-router-ssr-query": "catalog:",
    "@tanstack/react-start": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-icons": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@engine/playwright-config": "workspace:*",
    "@engine/typescript-config": "workspace:*",
    "@playwright/test": "catalog:",
    "@testing-library/jest-dom": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:"
  }
}
